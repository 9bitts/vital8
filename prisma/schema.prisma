model StockMovement {
  id                  String            @id @default(cuid())
  organizationId      String
  movementType        StockMovementType
  productId           String
  batchId             String?
  fromLocationId      String?
  toLocationId        String?
  quantity            Int
  unitCostCents       Int               @default(0)
  reason              String?
