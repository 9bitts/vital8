  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId, readAt])
  @@index([userId, createdAt])
}

model UserNotificationPreference {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  inAppEnabled   Boolean  @default(true)
  emailEnabled   Boolean  @default(false)
  categories     Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
}

model UserReportPreference {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  reportKey      String
  filters        Json     @default("{}")
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId, reportKey])
}

model ScheduledReport {
  id              String    @id @default(cuid())
  organizationId  String
  reportKey       String
  cronDayOfWeek   Int
  cronHour        Int       @default(7)
  recipientRole   Role?
  recipientUserId String?
  isActive        Boolean   @default(true)
  lastSentAt      DateTime?
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        Json     @default("{}")
  cnes           String?
  documentNumber String?
  isActive       Boolean  @default(true)
  isMain         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id])
  membershipBranches MembershipBranch[]
  rooms              Room[]
  scheduleTemplates  ScheduleTemplate[]
  appointments       Appointment[]
  cashRegisters      CashRegister[]
  stockLocations     StockLocation[]
  tissGuides         TissGuide[]
  tissBatches        TissBatch[]

  @@index([organizationId])
  @@index([isActive])
}

model MembershipBranch {
  id           String @id @default(cuid())
  membershipId String
  branchId     String

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([membershipId, branchId])
  @@index([branchId])
}

model PermissionProfile {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  roleTemplate   Role?
  permissions    Json     @default("{}")
  limits         Json     @default("{}")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  memberships  Membership[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @unique
  plan                   SubscriptionPlan   @default(BASICO)
  cycle                  SubscriptionCycle  @default(MONTHLY)
  status                 SubscriptionStatus @default(TRIAL)
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  gracePeriodEndsAt      DateTime?
  externalCustomerId     String?
  externalSubscriptionId String?
  limits                 Json               @default("{}")
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  invoices     SubscriptionInvoice[]

  @@index([status])
}

model SubscriptionInvoice {
  id             String   @id @default(cuid())
  subscriptionId String
  amountCents    Int
  status         String   @default("PENDING")
  periodStart    DateTime
  periodEnd      DateTime
  paidAt         DateTime?
  externalId     String?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
}

model OnboardingProgress {
  id             String    @id @default(cuid())
  organizationId String    @unique
  steps          Json      @default("{}")
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

enum OrganizationExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED
}

model OrganizationExport {
  id             String                   @id @default(cuid())
  organizationId String
  requestedById  String
  status         OrganizationExportStatus @default(PENDING)
  storageKey     String?
  downloadToken  String?                  @unique
  expiresAt      DateTime?
  errorMessage   String?
  createdAt      DateTime                 @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
}

enum ApiClientEnvironment {
  SANDBOX
  PRODUCTION
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DLQ
}

model ApiClient {
  id                          String               @id @default(cuid())
  organizationId              String
  name                        String
  environment                 ApiClientEnvironment @default(SANDBOX)
  isActive                    Boolean              @default(true)
  clinicalAccessEnabled       Boolean              @default(false)
  clinicalAccessJustification String?
  clinicalAccessEnabledAt     DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  keys              ApiKey[]
  requestLogs       ApiRequestLog[]
  webhookEndpoints  WebhookEndpoint[]
  idempotencyKeys   ApiIdempotencyRecord[]

  @@index([organizationId])
}

model ApiKey {
  id             String    @id @default(cuid())
  apiClientId    String
  organizationId String
  keyPrefix      String    @unique
  secretHash     String
  scopes         String[]
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  apiClient       ApiClient              @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  requestLogs     ApiRequestLog[]
  idempotencyKeys ApiIdempotencyRecord[]

  @@index([organizationId])
  @@index([apiClientId])
}

model ApiIdempotencyRecord {
  id             String   @id @default(cuid())
  organizationId String
  apiClientId    String
  apiKeyId       String
  idempotencyKey String
  method         String
  path           String
  statusCode     Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  apiClient ApiClient @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  apiKey    ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, idempotencyKey])
  @@index([expiresAt])
}

model ApiRequestLog {
  id             String   @id @default(cuid())
  organizationId String
  apiClientId    String
  apiKeyId       String
  method         String
  route          String
  statusCode     Int
  latencyMs      Int
  ipAddress      String?
  createdAt      DateTime @default(now())

  apiClient ApiClient @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  apiKey    ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([organizationId, apiClientId, createdAt])
  @@index([apiKeyId, createdAt])
}

model WebhookEndpoint {
  id                  String   @id @default(cuid())
  organizationId      String
  apiClientId         String
  url                 String
  secret              String
  events              String[]
  isActive            Boolean  @default(true)
  consecutiveFailures Int      @default(0)
  disabledAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  apiClient  ApiClient         @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@index([apiClientId])
}

model WebhookDelivery {
  id                String                @id @default(cuid())
  webhookEndpointId String
  organizationId    String
  eventType         String
  payload           Json
  status            WebhookDeliveryStatus @default(PENDING)
  attemptCount      Int                   @default(0)
  lastAttemptAt     DateTime?
  nextRetryAt       DateTime?
  responseStatus    Int?
  lastError         String?
  createdAt         DateTime              @default(now())

  webhookEndpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([webhookEndpointId])
  @@index([nextRetryAt])
}

enum AiResourceType {
  VIRTUAL_SECRETARY
  CLINICAL_COPILOT
  SMART_COLLECTION
  NO_SHOW_SCORING
  BI_INSIGHTS
  GLOSA_DRAFT
  SMART_SEARCH
}

enum AiInteractionOutcome {
  PENDING
  ACCEPTED
  EDITED
  REJECTED
}

enum AiConversationStatus {
  ACTIVE
  COMPLETED
  HANDOFF
}

enum AiConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AiSettings {
  id                  String   @id @default(cuid())
  organizationId      String   @unique
  enabledResources    Json     @default("{}")
  model               String   @default("claude-3-5-sonnet-latest")
  temperature         Float    @default(0.3)
  language            String   @default("pt-BR")
  silenceStartHour    Int?
  silenceEndHour      Int?
  monthlyTokenLimit   Int      @default(500000)
  monthlyAlertSentAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model AiDataProcessingConsent {
  id              String         @id @default(cuid())
  organizationId  String
  resource        AiResourceType
  termVersion     String
  grantedByUserId String
  grantedAt       DateTime       @default(now())
  revokedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, resource])
  @@index([organizationId])
}

model AiInteractionLog {
  id               String               @id @default(cuid())
  organizationId   String
  userId           String?
  resource         AiResourceType
  tokensUsed       Int                  @default(0)
  latencyMs        Int                  @default(0)
  outcome          AiInteractionOutcome @default(PENDING)
  payloadEncrypted String?
  createdAt        DateTime             @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, resource, createdAt])
}

model AiUsageMonthly {
  id             String @id @default(cuid())
  organizationId String
  yearMonth      String
  tokensUsed     Int    @default(0)
  requestCount   Int    @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, yearMonth])
}

model AiFaq {
  id             String   @id @default(cuid())
  organizationId String
  question       String
  answer         String
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
}

model AiConversation {
  id                      String               @id @default(cuid())
  organizationId          String
  channel                 CommunicationChannel @default(WHATSAPP)
  externalPhone           String
  patientId               String?
  status                  AiConversationStatus @default(ACTIVE)
  lastIntent              String?
  outcome                 String?
  handoffContextEncrypted String?
  sessionState            Json                 @default("{}")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id])
  patient      Patient?                @relation(fields: [patientId], references: [id])
  messages     AiConversationMessage[]

  @@index([organizationId, externalPhone])
  @@index([organizationId, status])
}

model AiConversationMessage {
  id               String                    @id @default(cuid())
  organizationId   String
  conversationId   String
  role             AiConversationMessageRole
  contentEncrypted String
  metadata         Json                      @default("{}")
  createdAt        DateTime                  @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([organizationId])
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  memberships     Membership[]
  invitationsSent Invitation[] @relation("InvitedBy")
  auditLogs       AuditLog[]
  userNotifications UserNotification[]
  notificationPreferences UserNotificationPreference[]
  reportPreferences UserReportPreference[]

  @@index([deletedAt])
}

model Membership {
  id                  String    @id @default(cuid())
  userId              String
  organizationId      String
  role                Role
  permissionProfileId String?
  branchAccessAll     Boolean   @default(true)
  professionalCouncil String?
  councilNumber       String?
  councilState        String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  user              User               @relation(fields: [userId], references: [id])
  organization      Organization       @relation(fields: [organizationId], references: [id])
  permissionProfile PermissionProfile? @relation(fields: [permissionProfileId], references: [id])
  membershipBranches MembershipBranch[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([permissionProfileId])
  @@index([deletedAt])
}

model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([email])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json     @default("{}")
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([createdAt])
  @@index([action])
}
