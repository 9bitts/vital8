generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  CPF
  CNPJ
}

enum OrganizationType {
  CLINICA
  CONSULTORIO
  PROFISSIONAL_AUTONOMO
  ASSOCIACAO
  LABORATORIO
  OUTRO
}

enum Plan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionPlan {
  BASICO
  PRO
  ENTERPRISE
}

enum SubscriptionCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL
  ATIVA
  INADIMPLENTE
  CANCELADA
}

enum Role {
  OWNER
  ADMIN
  PROFISSIONAL_SAUDE
  RECEPCAO
  FINANCEIRO
  ESTOQUE
  LEITURA
}

enum Sex {
  MASCULINO
  FEMININO
  INTERSEX
  NAO_INFORMADO
}

enum MaritalStatus {
  SOLTEIRO
  CASADO
  DIVORCIADO
  VIUVO
  UNIAO_ESTAVEL
  OUTRO
  NAO_INFORMADO
}

enum ConsentChannel {
  PRESENCIAL
  DIGITAL
  TELEFONE
  IMPORTACAO
}

enum PatientDocCategory {
  RG
  CPF
  COMPROVANTE_RESIDENCIA
  CARTEIRINHA_CONVENIO
  EXAME
  OUTRO
}

enum ProfessionalCouncil {
  CRM
  CRO
  CREFITO
  CRP
  CRN
  OUTRO
}

enum Weekday {
  DOMINGO
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  AGUARDANDO
  EM_ATENDIMENTO
  FINALIZADO
  FALTOU
  CANCELADO
  REMARCADO
}

enum AppointmentOrigin {
  RECEPCAO
  TELEFONE
  ONLINE
  API
}

enum OnlineApprovalStatus {
  NAO_APLICAVEL
  PENDENTE
  APROVADO
  REJEITADO
}

enum ConfirmationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum ConfirmationStatus {
  PENDENTE
  CONFIRMADO
  CANCELADO
  EXPIRADO
}

enum RecurrenceFrequency {
  WEEKLY
  BIWEEKLY
}

enum EncounterModality {
  PRESENCIAL
  TELECONSULTA
}

enum EncounterStatus {
  RASCUNHO
  ASSINADO
}

enum EncounterSectionType {
  ANAMNESE
  EXAME_FISICO
  EVOLUCAO_SOAP
  HIPOTESE_DIAGNOSTICA
  CONDUTA
  REGISTRO_RESERVADO
  PLANO_TRATAMENTO
  ANTROPOMETRIA
  EVOLUCAO_FISIO
  ODONTOGRAMA
}

enum PrescriptionType {
  COMUM
  CONTROLE_ESPECIAL
}

enum MedicalCertificateType {
  ATESTADO
  DECLARACAO
  COMPARECIMENTO
}

enum RecordResourceType {
  ENCOUNTER
  PRESCRIPTION
  EXAM_RESULT
  MEDICAL_CERTIFICATE
  ENCOUNTER_AMENDMENT
  PATIENT_PORTAL
}

enum FormFieldType {
  TEXT
  NUMBER
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  DATE
  TABLE
}

enum OdontogramEntryStatus {
  PLANEJADO
  REALIZADO
  EXISTENTE
}

enum SaleStatus {
  RASCUNHO
  CONFIRMADA
  CANCELADA
}

enum SaleItemType {
  SERVICE
  PACKAGE
  PRODUCT
}

enum ReceivableStatus {
  ABERTO
  PARCIAL
  PAGO
  VENCIDO
  CANCELADO
}

enum ReceivableOrigin {
  SALE
  AVULSO
  TISS_BATCH
}

enum PriorAuthorizationStatus {
  SOLICITADA
  AUTORIZADA
  NEGADA
  EXPIRADA
}

enum TissGuideType {
  GUIA_CONSULTA
  GUIA_SP_SADT
}

enum TissGuideStatus {
  RASCUNHO
  PRONTA
  EM_LOTE
  ENVIADA
  PAGA
  GLOSADA_PARCIAL
  GLOSADA_TOTAL
}

enum TissBatchStatus {
  ABERTO
  FECHADO
  ENVIADO
  CONCILIADO
  REABERTO
}

enum GlosaItemStatus {
  ACEITA
  EM_RECURSO
  RECUPERADA
  PERDIDA
}

enum TissSequenceType {
  GUIDE
  BATCH
}

enum TissAccidentIndication {
  NAO_ACIDENTE
  ACIDENTE_TRABALHO
  ACIDENTE_TRANSITO
  OUTROS_ACIDENTES
}

enum TissServiceCharacter {
  ELETIVO
  URGENCIA
}

enum TissConsultationType {
  PRIMEIRA
  SEGUIMENTO
  PRE_NATAL
  REFERENCIADA
}

enum PaymentMethod {
  DINHEIRO
  PIX
  DEBITO
  CREDITO
  TRANSFERENCIA
  LINK
}

enum PayableStatus {
  ABERTO
  PAGO
  CANCELADO
}

enum CashRegisterStatus {
  ABERTO
  FECHADO
}

enum CashRegisterEntryType {
  ABERTURA
  PAGAMENTO
  SANGRIA
  REFORCO
  ESTORNO
}

enum CommissionRuleType {
  PERCENTUAL
  FIXO
}

enum CommissionBase {
  FATURADO
  RECEBIDO
}

enum CommissionStatementStatus {
  ABERTO
  FECHADO
  PAGO
}

enum FinancialCategoryType {
  RECEITA
  DESPESA
}

enum PackagePurchaseStatus {
  ATIVO
  ESGOTADO
  CANCELADO
}

model Organization {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  documentType   DocumentType
  documentNumber String
  type           OrganizationType
  phone          String?
  email          String?
  address        Json             @default("{}")
  settings       Json             @default("{}")
  plan           Plan             @default(TRIAL)
  trialEndsAt    DateTime?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  memberships Membership[]
  invitations Invitation[]
  auditLogs   AuditLog[]
  patients    Patient[]
  professionals Professional[]
  services    Service[]
  rooms       Room[]
  scheduleTemplates ScheduleTemplate[]
  scheduleExceptions ScheduleException[]
  holidays    Holiday[]
  appointments Appointment[]
  waitingListEntries WaitingListEntry[]
  encounters Encounter[]
  formTemplates FormTemplate[]
  documentTemplates DocumentTemplate[]
  prescriptions Prescription[]
  examRequests ExamRequest[]
  examResults ExamResult[]
  recordAccessLogs RecordAccessLog[]
  priceTables PriceTable[]
  sales Sale[]
  packages Package[]
  packagePurchases PackagePurchase[]
  receivables Receivable[]
  payments Payment[]
  payables Payable[]
  suppliers Supplier[]
  financialCategories FinancialCategory[]
  bankAccounts BankAccount[]
  cashRegisters CashRegister[]
  commissionRules CommissionRule[]
  commissionStatements CommissionStatement[]
  refunds Refund[]
  healthInsurers HealthInsurer[]
  insurerContracts InsurerContract[]
  priorAuthorizations PriorAuthorization[]
  tissGuides TissGuide[]
  tissBatches TissBatch[]
  tissSequences TissSequence[]
  glosaItems GlosaItem[]
  insurerPayments InsurerPayment[]
  products Product[]
  stockLocations StockLocation[]
  stockBatches StockBatch[]
  stockBalances StockBalance[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  serviceConsumptionKits ServiceConsumptionKit[]
  inventories Inventory[]
  messageTemplates MessageTemplate[]
  automationRules AutomationRule[]
  communicationLogs CommunicationLog[]
  patientOptOuts PatientOptOut[]
  patientPortalOtps PatientPortalOtp[]
  patientPortalSessions PatientPortalSession[]
  onlineBookingConfig OnlineBookingConfig?
  teleconsultConsents TeleconsultConsent[]
  teleconsultRooms TeleconsultRoom[]
  npsSurveys NpsSurvey[]
  npsResponses NpsResponse[]
  releasedDocuments ReleasedDocument[]
  campaigns Campaign[]
  patientDataCorrectionRequests PatientDataCorrectionRequest[]
  dailyOrgMetrics DailyOrgMetrics[]
  dailyProfessionalMetrics DailyProfessionalMetrics[]
  performanceGoals PerformanceGoal[]
  scheduledReports ScheduledReport[]
  userNotifications UserNotification[]
  branches          Branch[]
  permissionProfiles PermissionProfile[]
  subscription      Subscription?
  onboardingProgress OnboardingProgress?
  organizationExports OrganizationExport[]
  apiClients          ApiClient[]
  aiSettings          AiSettings?
  aiDataProcessingConsents AiDataProcessingConsent[]
  aiInteractionLogs   AiInteractionLog[]
  aiUsageMonthly      AiUsageMonthly[]
  aiFaqs              AiFaq[]
  aiConversations     AiConversation[]

  @@index([deletedAt])
}

model Patient {
  id               String         @id @default(cuid())
  organizationId   String
  searchName       String
  fullName         String
  socialName       String?
  cpfEncrypted     String?
  cpfHash          String?
  rgEncrypted      String?
  birthDate        DateTime?      @db.Date
  sex              Sex?
  genderIdentity   String?
  maritalStatus    MaritalStatus?
  profession       String?
  phonesEncrypted  String?
  phoneSearch      String?
  emailEncrypted   String?
  addressEncrypted String?
  photoUrl         String?
  notesEncrypted   String?
  referralSource   String?
  tags             String[]       @default([])
  isIncomplete     Boolean        @default(false)
  isActive         Boolean        @default(true)
  anonymizedAt     DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  organization      Organization           @relation(fields: [organizationId], references: [id])
  guardians         PatientGuardian[]
  insurancePlans    PatientInsurancePlan[]
  consents          PatientConsent[]
  documents         PatientDocument[]
  allergies         Allergy[]
  chronicConditions ChronicCondition[]
  medications       PatientMedication[]
  appointments      Appointment[]
  waitingListEntries WaitingListEntry[]
  encounters        Encounter[]
  prescriptions     Prescription[]
  examRequests      ExamRequest[]
  examResults       ExamResult[]
  medicalCertificates MedicalCertificate[]
  sales             Sale[]
  receivables       Receivable[]
  payments          Payment[]
  packagePurchases  PackagePurchase[]
  priorAuthorizations PriorAuthorization[]
  communicationLogs CommunicationLog[]
  patientOptOuts PatientOptOut[]
  patientPortalOtps PatientPortalOtp[]
  patientPortalSessions PatientPortalSession[]
  teleconsultConsents TeleconsultConsent[]
  npsSurveys NpsSurvey[]
  releasedDocuments ReleasedDocument[]
  dataCorrectionRequests PatientDataCorrectionRequest[]
  aiConversations AiConversation[]

  @@unique([organizationId, cpfHash])
  @@index([organizationId, searchName])
  @@index([organizationId, birthDate])
  @@index([organizationId, phoneSearch])
  @@index([deletedAt])
}

model PatientGuardian {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  fullName       String
  cpfEncrypted   String?
  phoneEncrypted String?
  relationship   String
  isPrimary      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model PatientInsurancePlan {
  id                  String    @id @default(cuid())
  organizationId      String
  patientId           String
  healthInsurerId     String?
  insurerName         String
  planName            String?
  cardNumberEncrypted String
  cardNumberSearch    String?
  validUntil          DateTime? @db.Date
  isPrimary           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  patient        Patient         @relation(fields: [patientId], references: [id])
  healthInsurer  HealthInsurer?  @relation(fields: [healthInsurerId], references: [id])
  appointments   Appointment[]

  @@index([organizationId])
  @@index([patientId])
  @@index([healthInsurerId])
  @@index([organizationId, cardNumberSearch])
  @@index([deletedAt])
}

model PatientConsent {
  id             String         @id @default(cuid())
  organizationId String
  patientId      String
  termKey        String
  termVersion    String
  purpose        String
  channel        ConsentChannel
  grantedAt      DateTime       @default(now())
  revokedAt      DateTime?
  recordedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model PatientDocument {
  id             String             @id @default(cuid())
  organizationId String
  patientId      String
  category       PatientDocCategory @default(OUTRO)
  fileName       String
  mimeType       String
  fileSize       Int
  storageKey     String
  uploadedById   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model Allergy {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  substance      String
  severity       String?
  notesEncrypted String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model ChronicCondition {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  condition      String
  cidCode        String?
  diagnosedAt    DateTime? @db.Date
  notesEncrypted String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model PatientMedication {
  id             String    @id @default(cuid())
  organizationId String
  patientId      String
  name           String
  dosage         String?
  frequency      String?
  route          String?
  isActive       Boolean   @default(true)
  notesEncrypted String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model Professional {
  id             String              @id @default(cuid())
  organizationId String
  userId         String?
  displayName    String
  councilType    ProfessionalCouncil?
  councilNumber  String?
  councilState   String?
  specialties    String[]            @default([])
  color          String              @default("#3B82F6")
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  organization       Organization         @relation(fields: [organizationId], references: [id])
  scheduleTemplates  ScheduleTemplate[]
  scheduleExceptions ScheduleException[]
  appointments       Appointment[]
  waitingListEntries WaitingListEntry[]
  encounters         Encounter[]
  sales              Sale[]
  commissionRules    CommissionRule[]
  commissionStatements CommissionStatement[]
  dailyMetrics       DailyProfessionalMetrics[]
  performanceGoals   PerformanceGoal[]

  @@index([organizationId])
  @@index([deletedAt])
}

model Service {
  id                     String    @id @default(cuid())
  organizationId         String
  name                   String
  category               String?
  durationMinutes        Int
  privatePrice           Decimal   @default(0) @db.Decimal(10, 2)
  tussCode               String?
  tussProcedureId        String?
  preparationInstructions String?
  allowOnlineBooking     Boolean   @default(false)
  isTeleconsult          Boolean   @default(false)
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  organization       Organization       @relation(fields: [organizationId], references: [id])
  tussProcedure      TussProcedure?     @relation(fields: [tussProcedureId], references: [id])
  appointments       Appointment[]
  waitingListEntries WaitingListEntry[]
  priceTableItems    PriceTableItem[]
  saleItems          SaleItem[]
  packages           Package[]
  priorAuthorizations PriorAuthorization[]
  consumptionKit     ServiceConsumptionKit?
  automationRules    AutomationRule[]

  @@index([organizationId])
  @@index([tussProcedureId])
  @@index([deletedAt])
}

model Room {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization      Organization       @relation(fields: [organizationId], references: [id])
  branch            Branch?            @relation(fields: [branchId], references: [id])
  scheduleTemplates ScheduleTemplate[]
  appointments      Appointment[]
  stockLocation     StockLocation?

  @@index([organizationId])
  @@index([branchId])
  @@index([deletedAt])
}

model ScheduleTemplate {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  professionalId String
  weekday        Weekday
  startTime      String
  endTime        String
  slotIntervalMinutes Int @default(30)
  defaultRoomId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  defaultRoom  Room?        @relation(fields: [defaultRoomId], references: [id])

  @@index([organizationId])
  @@index([branchId])
  @@index([professionalId])
  @@index([deletedAt])
}

model ScheduleException {
  id             String   @id @default(cuid())
  organizationId String
  professionalId String
  startAt        DateTime
  endAt          DateTime
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([organizationId])
  @@index([professionalId])
  @@index([startAt, endAt])
  @@index([deletedAt])
}

model Holiday {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime @db.Date
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date])
  @@index([organizationId])
  @@index([deletedAt])
}

model Appointment {
  id                  String            @id @default(cuid())
  organizationId      String
  branchId            String?
  patientId           String
  professionalId      String
  serviceId           String
  roomId              String?
  startsAt            DateTime
  endsAt              DateTime
  status              AppointmentStatus @default(AGENDADO)
  origin              AppointmentOrigin @default(RECEPCAO)
  onlineApprovalStatus OnlineApprovalStatus @default(NAO_APLICAVEL)
  isPrivate           Boolean           @default(true)
  patientInsurancePlanId String?
  saleId              String?           @unique
  expectedAmount      Decimal?          @db.Decimal(10, 2)
  notes               String?
  isSqueeze           Boolean           @default(false)
  recurrenceGroupId   String?
  rescheduledFromId   String?
  arrivedAt           DateTime?
  startedAt           DateTime?
  finishedAt          DateTime?
  queueNumber         Int?
  cancelReason        String?
  calledAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  organization   Organization              @relation(fields: [organizationId], references: [id])
  branch         Branch?                   @relation(fields: [branchId], references: [id])
  patient        Patient                   @relation(fields: [patientId], references: [id])
  professional   Professional              @relation(fields: [professionalId], references: [id])
  service        Service                   @relation(fields: [serviceId], references: [id])
  room           Room?                     @relation(fields: [roomId], references: [id])
  statusHistory  AppointmentStatusHistory[]
  confirmations  AppointmentConfirmation[]
  encounter      Encounter?
  sale           Sale?                     @relation(fields: [saleId], references: [id])
  patientInsurancePlan PatientInsurancePlan? @relation(fields: [patientInsurancePlanId], references: [id])
  tissGuide      TissGuide?
  packageConsumptions PackageSessionConsumption[]
  stockMovements StockMovement[]
  teleconsultConsent TeleconsultConsent?
  npsSurvey NpsSurvey?

  @@index([organizationId])
  @@index([branchId])
  @@index([patientInsurancePlanId])
  @@index([professionalId, startsAt])
  @@index([patientId, startsAt])
  @@index([roomId, startsAt])
  @@index([status])
  @@index([startsAt])
  @@index([deletedAt])
}

model AppointmentStatusHistory {
  id             String             @id @default(cuid())
  organizationId String
  appointmentId  String
  fromStatus     AppointmentStatus?
  toStatus       AppointmentStatus
  changedById    String?
  changedAt      DateTime           @default(now())
  metadata       Json               @default("{}")

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([organizationId])
  @@index([appointmentId])
}

model WaitingListEntry {
  id                     String    @id @default(cuid())
  organizationId         String
  patientId              String
  serviceId              String
  preferredProfessionalId String?
  preferredPeriodStart   DateTime?
  preferredPeriodEnd     DateTime?
  priority               Int       @default(0)
  notes                  String?
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  organization          Organization  @relation(fields: [organizationId], references: [id])
  patient               Patient       @relation(fields: [patientId], references: [id])
  service               Service       @relation(fields: [serviceId], references: [id])
  preferredProfessional Professional? @relation(fields: [preferredProfessionalId], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([deletedAt])
}

model AppointmentConfirmation {
  id             String              @id @default(cuid())
  organizationId String
  appointmentId  String
  channel        ConfirmationChannel
  token          String              @unique
  status         ConfirmationStatus  @default(PENDENTE)
  sentAt         DateTime            @default(now())
  respondedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([organizationId])
  @@index([appointmentId])
}

model Cid10Code {
  id          String @id @default(cuid())
  code        String @unique
  description String
  chapter     String?

  @@index([description])
}

model DrugCatalog {
  id               String  @id @default(cuid())
  name             String
  activeIngredient String?
  concentration    String?
  pharmaceuticalForm String?
  route            String?
  isControlled     Boolean @default(false)

  prescriptionItems PrescriptionItem[]

  @@index([name])
}

model Encounter {
  id              String            @id @default(cuid())
  organizationId  String
  appointmentId   String?           @unique
  patientId       String
  professionalId  String
  authorUserId    String
  modality        EncounterModality @default(PRESENCIAL)
  specialty       String?
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  status          EncounterStatus   @default(RASCUNHO)
  contentHash     String?
  signedAt        DateTime?
  signatureMeta   Json              @default("{}")
  teleconsultConsentId String?       @unique
  professionalJoinedAt DateTime?
  patientJoinedAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  organization   Organization        @relation(fields: [organizationId], references: [id])
  appointment    Appointment?        @relation(fields: [appointmentId], references: [id])
  patient        Patient             @relation(fields: [patientId], references: [id])
  professional   Professional        @relation(fields: [professionalId], references: [id])
  sections       EncounterSection[]
  amendments     EncounterAmendment[]
  prescriptions  Prescription[]
  examRequests   ExamRequest[]
  examResults    ExamResult[]
  certificates   MedicalCertificate[]
  formResponses  FormResponse[]
  odontogram     Odontogram?
  bodyChartEntries BodyChartEntry[]
  stockMovements StockMovement[]
  teleconsultConsent TeleconsultConsent? @relation(fields: [teleconsultConsentId], references: [id])
  teleconsultRoom TeleconsultRoom?
  npsSurvey NpsSurvey?

  @@index([organizationId])
  @@index([patientId, startedAt])
  @@index([professionalId])
  @@index([status])
  @@index([deletedAt])
}

model EncounterSection {
  id                 String               @id @default(cuid())
  organizationId     String
  encounterId        String
  sectionType        EncounterSectionType
  contentEncrypted   String?
  structuredData     Json                 @default("{}")
  restrictedToAuthor Boolean              @default(false)
  sortOrder          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

