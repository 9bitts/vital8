<?xml version="1.0" encoding="UTF-8"?>
<!-- Subset estrutural TISS 4.03.00 para validação de referência. -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
  targetNamespace="http://www.ans.gov.br/padroes/tiss/schemas"
  xmlns:tiss="http://www.ans.gov.br/padroes/tiss/schemas"
  elementFormDefault="qualified">

  <xs:element name="mensagemTISS">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="cabecalho" type="tiss:Cabecalho403Type"/>
        <xs:element name="prestadorParaOperadora" type="tiss:PrestadorParaOperadoraType"/>
        <xs:element name="epilogo" type="tiss:EpilogoType"/>
      </xs:sequence>
      <xs:attribute name="versao" type="xs:string" fixed="4.03.00" use="required"/>
    </xs:complexType>
  </xs:element>

  <xs:complexType name="Cabecalho403Type">
    <xs:sequence>
      <xs:element name="identificacaoTransacao" type="tiss:IdentificacaoTransacaoType"/>
      <xs:element name="origem" type="tiss:OrigemType"/>
      <xs:element name="destino" type="tiss:DestinoType"/>
      <xs:element name="componenteOrganizacional" type="tiss:ComponenteOrganizacionalType"/>
      <xs:element name="identificacaoSoftware" type="tiss:IdentificacaoSoftwareType"/>
      <xs:element name="competencia" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ComponenteOrganizacionalType">
    <xs:sequence>
      <xs:element name="identificacaoUnidade" type="tiss:IdentificacaoUnidadeType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IdentificacaoUnidadeType">
    <xs:sequence>
      <xs:element name="codigoCNES" type="xs:string"/>
      <xs:element name="nomeUnidade" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IdentificacaoSoftwareType">
    <xs:sequence>
      <xs:element name="nomeSoftware" type="xs:string"/>
      <xs:element name="versaoSoftware" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IdentificacaoTransacaoType">
    <xs:sequence>
      <xs:element name="tipoTransacao" type="xs:string"/>
      <xs:element name="sequencialTransacao" type="xs:integer"/>
      <xs:element name="dataRegistroTransacao" type="xs:date"/>
      <xs:element name="horaRegistroTransacao" type="xs:time"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="OrigemType">
    <xs:sequence>
      <xs:element name="identificacaoPrestador" type="tiss:IdentificacaoPrestadorType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IdentificacaoPrestadorType">
    <xs:sequence>
      <xs:element name="codigoCNES" type="xs:string"/>
      <xs:element name="cnpjContratado" type="xs:string"/>
      <xs:element name="codigoPrestadorNaOperadora" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DestinoType">
    <xs:sequence>
      <xs:element name="registroANS" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PrestadorParaOperadoraType">
    <xs:sequence>
      <xs:element name="loteGuias" type="tiss:LoteGuiasType"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LoteGuiasType">
    <xs:sequence>
      <xs:element name="numeroLote" type="xs:integer"/>
      <xs:element name="guias" type="tiss:Guias403Type"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Guias403Type">
    <xs:choice maxOccurs="unbounded">
      <xs:element name="guiaConsulta" type="tiss:GuiaConsulta403Type"/>
      <xs:element name="guiaSP-SADT" type="tiss:GuiaSpSadt403Type"/>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="GuiaConsulta403Type">
    <xs:sequence>
      <xs:element name="cabecalhoGuia" type="tiss:CabecalhoGuiaType"/>
      <xs:element name="dadosBeneficiario" type="tiss:DadosBeneficiarioType"/>
      <xs:element name="dadosExecutante" type="tiss:DadosExecutanteType"/>
      <xs:element name="procedimentosExecutados" type="tiss:Procedimentos403Type"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="GuiaSpSadt403Type">
    <xs:sequence>
      <xs:element name="cabecalhoGuia" type="tiss:CabecalhoGuiaType"/>
      <xs:element name="dadosBeneficiario" type="tiss:DadosBeneficiarioType"/>
      <xs:element name="dadosExecutante" type="tiss:DadosExecutanteType"/>
      <xs:element name="procedimentosExecutados" type="tiss:Procedimentos403Type"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CabecalhoGuiaType">
    <xs:sequence>
      <xs:element name="registroANS" type="xs:string"/>
      <xs:element name="numeroGuiaPrestador" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DadosBeneficiarioType">
    <xs:sequence>
      <xs:element name="numeroCarteira" type="xs:string"/>
      <xs:element name="nomeBeneficiario" type="xs:string"/>
      <xs:element name="validadeCarteira" type="xs:date" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DadosExecutanteType">
    <xs:sequence>
      <xs:element name="codigoCNES" type="xs:string" minOccurs="0"/>
      <xs:element name="cnpjContratado" type="xs:string" minOccurs="0"/>
      <xs:element name="cpfContratado" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Procedimentos403Type">
    <xs:sequence>
      <xs:element name="procedimentoExecutado" type="tiss:ProcedimentoExecutado403Type" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ProcedimentoExecutado403Type">
    <xs:sequence>
      <xs:element name="sequencialItem" type="xs:positiveInteger"/>
      <xs:element name="codigoTabela" type="xs:string"/>
      <xs:element name="codigoProcedimento" type="xs:string"/>
      <xs:element name="quantidadeExecutada" type="xs:positiveInteger"/>
      <xs:element name="valorUnitario" type="xs:decimal"/>
      <xs:element name="valorTotal" type="xs:decimal"/>
      <xs:element name="dataExecucao" type="xs:date"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="EpilogoType">
    <xs:sequence>
      <xs:element name="hash" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>
</xs:schema>
