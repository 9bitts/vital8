# Variáveis de ambiente — Vital8 Fase 1

# PostgreSQL (Railway ou local)
# Exemplo Railway: postgresql://user:pass@host:5432/railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vital8?schema=public"

# Auth.js v5 — gere com:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="substitua-por-chave-aleatoria-de-32-bytes-em-base64"

# Criptografia PHI (AES-256-GCM) — gere com:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
PHI_ENCRYPTION_KEY="substitua-por-chave-aleatoria-de-32-bytes-em-base64"

# CPF_HASH_KEY — HMAC-SHA256 para cpfHash (32 bytes base64)
CPF_HASH_KEY="substitua-por-chave-aleatoria-de-32-bytes-em-base64"

# URL pública da aplicação (opcional em dev)
AUTH_URL="http://localhost:3000"

# SSO Doctor8 — login OIDC (mesmo client secret registrado em SSO_VITAL8_* no doctor8)
# Issuer: URL pública do app doctor8 (sem barra final)
AUTH_DOCTOR8_ISSUER="https://app.doctor8.org"
# Client ID e secret — devem coincidir com SSO_VITAL8_CLIENT_ID / SSO_VITAL8_CLIENT_SECRET no doctor8
AUTH_DOCTOR8_ID="vital8"
AUTH_DOCTOR8_SECRET="substitua-pelo-mesmo-secret-do-SSO_VITAL8_CLIENT_SECRET"

# Fase 16F — Comunicação e pagamentos (opcional; sem valor = mock/console)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_DEFAULT_COUNTRY_CODE=55
WHATSAPP_TEMPLATE_LANG=pt_BR
WHATSAPP_REMINDER_TEMPLATE=vital8_lembrete
WHATSAPP_CONFIRM_TEMPLATE=vital8_confirmacao
WHATSAPP_BILLING_TEMPLATE=vital8_cobranca
WHATSAPP_NPS_TEMPLATE=vital8_nps
# Alias legado 16F (mesmo valor que WHATSAPP_APP_SECRET):
WHATSAPP_WEBHOOK_SECRET=
RESEND_API_KEY=
EMAIL_FROM="Vital8 <noreply@vital8.app>"
EMAIL_REPLY_TO=
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX_KEY=
EFI_SANDBOX=true
PAYMENTS_WEBHOOK_SECRET=

# Fase 17C — Stripe (opcional; sem valor = mock billing + PIX mock/Efí)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENTS_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SUBSCRIPTION_PIX=0
STRIPE_PRICE_BASICO_MONTHLY=
STRIPE_PRICE_BASICO_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# Fase 17A — Lacuna ICP-Brasil (opcional; sem valor = ICP_LACUNA indisponível)
LACUNA_API_KEY=
LACUNA_ENDPOINT=https://core.pki.rest
LACUNA_SECURITY_CONTEXT=

# Fase 17D — Daily.co teleconsulta (opcional; sem valor = Jitsi público)
DAILY_API_KEY=
DAILY_WEBHOOK_SECRET=
DAILY_CLOUD_RECORDING=0
E2E_MOCK_DAILY=0

# Fase 17E — IA clínica (opcional; sem valor = mock determinístico)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
E2E_MOCK_OPENAI=0

# Fase 17G — Infra (opcional; sem valor = local/console)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_S3_BUCKET=
AWS_SNS_SMS_ENABLED=0
AWS_SNS_SMS_PRODUCTION=0
AWS_SNS_REGION=
AWS_SNS_SENDER_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
E2E_MOCK_SNS=0
